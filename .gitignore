# =============================================================================
# FINESE 2 - AI-Powered Data Intelligence Platform (Flask)
# =============================================================================
# Comprehensive .gitignore for Flask-based data science application
# Last updated: 2026-06-26
# =============================================================================

# =============================================================================
# Python
# =============================================================================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

# C extensions
*.o

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# =============================================================================
# Virtual Environments
# =============================================================================
venv/
env/
ENV/
.venv/
.env.*/

# =============================================================================
# IDEs & Editors
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject
.settings/
*.sublime-project
*.sublime-workspace
*.code-workspace

# =============================================================================
# Operating System Files
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# =============================================================================
# Logs & Debugging
# =============================================================================
*.log
logs/
debug.log
error.log
access.log
*.log.*

# =============================================================================
# Testing & Coverage
# =============================================================================
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/
.mypy_cache/
.ropeproject/

# =============================================================================
# Jupyter Notebooks
# =============================================================================
.ipynb_checkpoints
*.ipynb

# =============================================================================
# Environment Variables & Secrets
# =============================================================================
.env
.env.local
.env.dev
.env.prod
.env.test
*.env.*
!requirements.txt

# =============================================================================
# Flask-Specific
# =============================================================================
# Server-side session files (auto-generated at runtime)
flask_session/

# Flask instance folder (for production configs)
instance/

# Flask web assets cache
.webassets-cache

# Flask upload directory (user-uploaded datasets)
static/uploads/*.csv
static/uploads/*.xlsx
static/uploads/*.xls
static/uploads/*.json
static/uploads/*.parquet
static/uploads/*.h5
static/uploads/*.pkl
static/uploads/*.joblib
static/uploads/*.pickle
static/uploads/*.feather

# Keep .gitkeep to preserve directory structure in git
!static/uploads/.gitkeep

# =============================================================================
# Exported Files & Reports (Generated at Runtime)
# =============================================================================
static/exports/*
!static/exports/.gitkeep

static/reports/*
!static/reports/.gitkeep

# =============================================================================
# Machine Learning Models & Artifacts
# =============================================================================
# Serialized models and checkpoints
models/*.pkl
models/*.joblib
models/*.bin
models/*.pt
models/*.pth
models/*.ckpt
models/*.onnx
models/*.h5
models/*.model
models/*.weights

# Keep models directory structure
!models/.gitkeep

# ML training artifacts
checkpoints/
artifacts/
tensorboard_logs/
wandb/

# =============================================================================
# Cache Directories
# =============================================================================
.cache/
pip-cache/
pip-download-cache/

# =============================================================================
# Documentation Build
# =============================================================================
docs/_build/
site/
_build/

# =============================================================================
# Temporary Files
# =============================================================================
*.tmp
*.temp
*.bak
*.backup
*~
*.swp
*.swo

# OS-specific temporary files
$RECYCLE.BIN/
System Volume Information/

# =============================================================================
# Database Files (if using SQLite or local databases)
# =============================================================================
*.db
*.sqlite
*.sqlite3
*.db-journal

# =============================================================================
# Docker
# =============================================================================
.docker/
docker-compose.override.yml

# =============================================================================
# Streamlit Legacy (Removed in Flask Migration)
# =============================================================================
# These are from the old Streamlit version - safe to ignore
.streamlit/
streamlit/

# =============================================================================
# Data Science Specific
# =============================================================================
# DVC (Data Version Control)
.dvc/
dvc.lock

# MLflow
mlruns/

# Weights & Biases
wandb/

# Optuna study storage
optuna.db
study.db

# =============================================================================
# Security & Credentials
# =============================================================================
# API keys, tokens, credentials
credentials.json
service-account.json
*.pem
*.key
secrets/
keys/

# =============================================================================
# Build Outputs
# =============================================================================
# Compiled assets
static/dist/
static/build/

# Webpack
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =============================================================================
# IDE-Specific Configurations
# =============================================================================
# VS Code
.vscode/settings.json
.vscode/launch.json
.vscode/tasks.json

# PyCharm
.idea/workspace.xml
.idea/tasks.xml
.idea/dictionaries/
.idea/vcs.xml
.idea/modules.xml

# =============================================================================
# Performance Profiling
# =============================================================================
*.prof
profile/
cprofile/

# =============================================================================
# End of .gitignore
# =============================================================================