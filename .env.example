# ============================================
# FINESE2 - Environment Configuration Example
# Copy this file to .env and update with your values
# ============================================

# Application Settings
SECRET_KEY=your-super-secret-key-change-this-in-production
FLASK_ENV=development
FLASK_DEBUG=1

# Database Configuration
# SQLite (default for development)
DATABASE_URL=sqlite:///instance/finese2.db

# PostgreSQL (for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/finese2

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# JWT Authentication (set ENABLE_JWT=true to enable)
ENABLE_JWT=false
JWT_SECRET_KEY=your-jwt-secret-key-change-this

# AI Provider API Keys (optional - add as needed)
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
GOOGLE_API_KEY=AIza-your-google-key

# File Upload Settings
MAX_UPLOAD_SIZE=50
DEFAULT_SAMPLE_SIZE=10000
MAX_ROWS_FOR_ANALYSIS=100000

# Logging
LOG_LEVEL=INFO

# CORS Configuration
ALLOWED_ORIGINS=*

# Rate Limiting
RATELIMIT_DEFAULT=100 per hour
